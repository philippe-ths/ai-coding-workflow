{
  "uid": "aiw-session-overview",
  "title": "Session Overview",
  "tags": ["ai-coding-workflow", "claude-code"],
  "schemaVersion": 39,
  "timezone": "browser",
  "time": { "from": "now-7d", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "workflow_version",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(claude_code_session_count_total, workflow_version)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Sessions (range)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(claude_code_session_count_total{workflow_version=~\"$workflow_version\"}[$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "decimals": 0, "unit": "none" } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total cost (USD, range)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total{workflow_version=~\"$workflow_version\"}[$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "decimals": 2, "unit": "currencyUSD" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active time (range)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(claude_code_active_time_total{workflow_version=~\"$workflow_version\"}[$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "decimals": 0, "unit": "s" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total tokens (range)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total{workflow_version=~\"$workflow_version\"}[$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "decimals": 0, "unit": "short" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Token usage by type",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total{workflow_version=~\"$workflow_version\"}[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Cost per 5m",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (model) (rate(claude_code_cost_usage_USD_total{workflow_version=~\"$workflow_version\"}[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Lines of code changed",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (type) (rate(claude_code_lines_of_code_count_total{workflow_version=~\"$workflow_version\"}[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Commits + PRs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(claude_code_commit_count_total{workflow_version=~\"$workflow_version\"}[5m]))",
          "legendFormat": "commits",
          "refId": "A"
        },
        {
          "expr": "sum(rate(claude_code_pull_request_count_total{workflow_version=~\"$workflow_version\"}[5m]))",
          "legendFormat": "pull requests",
          "refId": "B"
        }
      ]
    }
  ]
}
